{
  "name": "hono-query-rpc",
  "version": "0.1.0",
  "description": "tRPC-style TanStack Query integration for Hono RPC",
  "license": "MIT",
  "author": "yanguk",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanguk/hono-query-rpc.git"
  },
  "bugs": {
    "url": "https://github.com/yanguk/hono-query-rpc/issues"
  },
  "homepage": "https://github.com/yanguk/hono-query-rpc#readme",
  "keywords": [
    "hono",
    "hono-rpc",
    "tanstack-query",
    "react-query",
    "trpc"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": ["example"],
  "scripts": {
    "dev": "tsdown --watch & bun run --filter hono-query-rpc-example dev",
    "build": "tsdown",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build",
    "release": "bun scripts/release.ts"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@happy-dom/global-registrator": "^20.8.4",
    "@tanstack/react-query": "^5.91.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "hono": "^4.12.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "latest",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
