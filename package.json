{
  "name": "honoq",
  "version": "0.1.0",
  "description": "tRPC-style TanStack Query integration for Hono RPC",
  "license": "MIT",
  "author": "yanguk",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanguk/honoq.git"
  },
  "bugs": {
    "url": "https://github.com/yanguk/honoq/issues"
  },
  "homepage": "https://github.com/yanguk/honoq#readme",
  "keywords": [
    "hono",
    "hono-rpc",
    "tanstack-query",
    "react-query",
    "trpc"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.91.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
